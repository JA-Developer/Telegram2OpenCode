@page "/telegram-bots/create"
@rendermode InteractiveServer
@inject ITelegramBotRepository BotRepo
@inject NavigationManager Navigation

<PageTitle>Create Telegram Bot</PageTitle>

<div class="mb-4">
    <a href="telegram-bots" class="btn btn-sm btn-outline-secondary rounded-2 mb-2">
        <span class="bi bi-arrow-left me-1"></span> Back to list
    </a>
    <h1 class="display-6 fw-semibold">Create Telegram Bot</h1>
    <p class="text-muted">Add a new Telegram bot to manage.</p>
</div>

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-body p-4">
        <EditForm Model="@dto" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label for="name" class="form-label fw-semibold">Name</label>
                <InputText id="name" class="form-control rounded-2" placeholder="e.g. My Support Bot" @bind-Value="dto.Name" />
                <ValidationMessage For="@(() => dto.Name)" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="username" class="form-label fw-semibold">Username</label>
                <InputText id="username" class="form-control rounded-2" placeholder="e.g. MySupportBot" @bind-Value="dto.Username" />
            </div>

            <div class="mb-3">
                <label for="token" class="form-label fw-semibold">Token</label>
                <InputText id="token" class="form-control rounded-2 font-monospace" placeholder="1234567890:ABCdefGHIjklMNOpqrsTUVwxyz" @bind-Value="dto.Token" />
                <ValidationMessage For="@(() => dto.Token)" class="text-danger" />
            </div>

            <div class="mb-4">
                <label for="welcomeMessage" class="form-label fw-semibold">Welcome Message</label>
                <InputTextArea id="welcomeMessage" class="form-control rounded-2" placeholder="Message sent when a user starts the bot..." @bind-Value="dto.WelcomeMessage" rows="3" />
            </div>

            <div class="mb-4 form-check form-switch">
                <InputCheckbox id="isRunning" class="form-check-input" @bind-Value="dto.IsRunning" />
                <label for="isRunning" class="form-check-label fw-semibold">Start running immediately</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary rounded-2 px-4">
                    <span class="bi bi-check-lg me-1"></span> Create
                </button>
                <a href="telegram-bots" class="btn btn-outline-secondary rounded-2 px-4">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private readonly CreateTelegramBotDto dto = new();

    private async Task HandleSubmit()
    {
        var entity = dto.ToEntity();
        await BotRepo.CreateAsync(entity);
        Navigation.NavigateTo("telegram-bots");
    }
}
