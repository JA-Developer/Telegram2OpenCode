@page "/telegram-bots/edit/{Id:int}"
@rendermode InteractiveServer
@inject ITelegramBotRepository BotRepo
@inject NavigationManager Navigation

<PageTitle>Edit Telegram Bot</PageTitle>

<div class="mb-4">
    <a href="telegram-bots" class="btn btn-sm btn-outline-secondary rounded-2 mb-2">
        <span class="bi bi-arrow-left me-1"></span> Back to list
    </a>
    <h1 class="display-6 fw-semibold">Edit Telegram Bot</h1>
    <p class="text-muted">Update the bot configuration.</p>
</div>

@if (entity is null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 text-muted">Loading bot...</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-4">
            <EditForm Model="@dto" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />

                <div class="mb-3">
                    <label for="name" class="form-label fw-semibold">Name</label>
                    <InputText id="name" class="form-control rounded-2" @bind-Value="dto.Name" />
                    <ValidationMessage For="@(() => dto.Name)" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="username" class="form-label fw-semibold">Username</label>
                    <InputText id="username" class="form-control rounded-2" @bind-Value="dto.Username" />
                </div>

                <div class="mb-3">
                    <label for="token" class="form-label fw-semibold">Token</label>
                    <InputText id="token" class="form-control rounded-2 font-monospace" @bind-Value="dto.Token" />
                    <ValidationMessage For="@(() => dto.Token)" class="text-danger" />
                </div>

                <div class="mb-4">
                    <label for="welcomeMessage" class="form-label fw-semibold">Welcome Message</label>
                    <InputTextArea id="welcomeMessage" class="form-control rounded-2" @bind-Value="dto.WelcomeMessage" rows="3" />
                </div>

                <div class="mb-3 form-check form-switch">
                    <InputCheckbox id="isActive" class="form-check-input" @bind-Value="dto.IsActive" />
                    <label for="isActive" class="form-check-label fw-semibold">Active</label>
                </div>

                <div class="mb-4 form-check form-switch">
                    <InputCheckbox id="isRunning" class="form-check-input" @bind-Value="dto.IsRunning" />
                    <label for="isRunning" class="form-check-label fw-semibold">Running</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-2 px-4">
                        <span class="bi bi-check-lg me-1"></span> Save
                    </button>
                    <a href="telegram-bots" class="btn btn-outline-secondary rounded-2 px-4">Cancel</a>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private TelegramBot? entity;
    private UpdateTelegramBotDto dto = new();

    protected override async Task OnInitializedAsync()
    {
        entity = await BotRepo.GetByIdAsync(Id);

        if (entity is not null)
        {
            dto.Name = entity.Name;
            dto.Username = entity.Username;
            dto.Token = entity.Token;
            dto.WelcomeMessage = entity.WelcomeMessage;
            dto.IsActive = entity.IsActive;
            dto.IsRunning = entity.IsRunning;
        }
    }

    private async Task HandleSubmit()
    {
        if (entity is null) return;

        entity.ApplyUpdate(dto);
        await BotRepo.UpdateAsync(entity);
        Navigation.NavigateTo("telegram-bots");
    }
}
