@page "/telegram-bots/delete/{Id:int}"
@rendermode InteractiveServer
@inject ITelegramBotRepository BotRepo
@inject NavigationManager Navigation

<PageTitle>Delete TelegramBot</PageTitle>

<h1>Delete Telegram Bot</h1>

@if (entity is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="alert alert-danger">
        <h4>Are you sure you want to delete this?</h4>
    </div>

    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@entity.Name</dd>

        <dt class="col-sm-2">Username</dt>
        <dd class="col-sm-10">@entity.Username</dd>

        <dt class="col-sm-2">Token</dt>
        <dd class="col-sm-10">@entity.Token</dd>

        <dt class="col-sm-2">Active</dt>
        <dd class="col-sm-10">@entity.IsActive</dd>

        <dt class="col-sm-2">Running</dt>
        <dd class="col-sm-10">@entity.IsRunning</dd>
    </dl>

    <form>
        <button type="submit" class="btn btn-danger" @onclick="HandleDelete">Delete</button>
        <a href="telegram-bots" class="btn btn-secondary">Cancel</a>
    </form>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private TelegramBot? entity;

    protected override async Task OnInitializedAsync()
    {
        entity = await BotRepo.GetByIdAsync(Id);
    }

    private async Task HandleDelete()
    {
        await BotRepo.DeleteAsync(Id);
        Navigation.NavigateTo("telegram-bots");
    }
}
