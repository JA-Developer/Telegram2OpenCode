@page "/telegram-bots/delete/{Id:int}"
@rendermode InteractiveServer
@inject ITelegramBotRepository BotRepo
@inject NavigationManager Navigation

<PageTitle>Delete Telegram Bot</PageTitle>

<div class="mb-4">
    <a href="telegram-bots" class="btn btn-sm btn-outline-secondary rounded-2 mb-2">
        <span class="bi bi-arrow-left me-1"></span> Back to list
    </a>
    <h1 class="display-6 fw-semibold">Delete Telegram Bot</h1>
    <p class="text-muted">This action cannot be undone.</p>
</div>

@if (entity is null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 text-muted">Loading bot...</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-3 border-danger border-opacity-25">
        <div class="card-body p-4">
            <div class="alert alert-danger d-flex align-items-center gap-3 mb-4 rounded-3" role="alert">
                <span class="bi bi-exclamation-triangle-fill fs-4"></span>
                <div>
                    <strong>Are you sure?</strong><br>
                    This bot will be deactivated and hidden from the list.
                </div>
            </div>

            <div class="mb-4">
                <table class="table table-borderless mb-0">
                    <tr>
                        <td class="text-muted ps-0" style="width: 140px;">Name</td>
                        <td class="fw-semibold pe-0">@entity.Name</td>
                    </tr>
                    <tr>
                        <td class="text-muted ps-0">Username</td>
                        <td class="pe-0">
                            <span class="badge bg-light text-dark border px-3 py-2 rounded-2">
                                <span class="bi bi-at me-1"></span>@entity.Username
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted ps-0">Token</td>
                        <td class="pe-0">
                            <code>@entity.Token[..Math.Min(12, entity.Token.Length)]...</code>
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted ps-0">Active</td>
                        <td class="pe-0">
                            @if (entity.IsActive)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-2">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2 rounded-2">Inactive</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted ps-0">Running</td>
                        <td class="pe-0">
                            @if (entity.IsRunning)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-2">Running</span>
                            }
                            else
                            {
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2 rounded-2">Stopped</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="text-muted ps-0">Created</td>
                        <td class="pe-0">@entity.CreatedAt.ToShortDateString()</td>
                    </tr>
                </table>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger rounded-2 px-4" @onclick="HandleDelete">
                    <span class="bi bi-trash me-1"></span> Delete
                </button>
                <a href="telegram-bots" class="btn btn-outline-secondary rounded-2 px-4">Cancel</a>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private TelegramBot? entity;

    protected override async Task OnInitializedAsync()
    {
        entity = await BotRepo.GetByIdAsync(Id);
    }

    private async Task HandleDelete()
    {
        await BotRepo.DeleteAsync(Id);
        Navigation.NavigateTo("telegram-bots");
    }
}
