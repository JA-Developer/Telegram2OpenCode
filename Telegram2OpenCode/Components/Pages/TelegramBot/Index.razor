@page "/telegram-bots"
@rendermode InteractiveServer
@inject ITelegramBotRepository BotRepo

<PageTitle>Telegram Bots</PageTitle>

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="display-6 fw-semibold mb-1">Telegram Bots</h1>
            <p class="text-muted mb-0">Manage your Telegram bot configurations</p>
        </div>
        <a href="telegram-bots/create" class="btn btn-primary rounded-2 px-4">
            <span class="bi bi-plus-lg me-1"></span> Create Bot
        </a>
    </div>
</div>

@if (bots is null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 text-muted">Loading bots...</p>
    </div>
}
else if (bots.Count == 0)
{
    <div class="text-center py-5">
        <div class="mb-3" style="font-size: 3rem;">🤖</div>
        <h4 class="fw-semibold">No Telegram bots yet</h4>
        <p class="text-muted mb-3">Create your first bot to get started.</p>
        <a href="telegram-bots/create" class="btn btn-primary rounded-2 px-4">
            <span class="bi bi-plus-lg me-1"></span> Create Bot
        </a>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-3 bg-primary bg-opacity-10">
                <div class="card-body text-center py-3">
                    <div class="fs-4 fw-bold text-primary">@bots.Count</div>
                    <div class="small text-muted">Total Bots</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-3 bg-success bg-opacity-10">
                <div class="card-body text-center py-3">
                    <div class="fs-4 fw-bold text-success">@bots.Count(b => b.IsActive)</div>
                    <div class="small text-muted">Active</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-3 bg-info bg-opacity-10">
                <div class="card-body text-center py-3">
                    <div class="fs-4 fw-bold text-info">@bots.Count(b => b.IsRunning)</div>
                    <div class="small text-muted">Running</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-3 bg-secondary bg-opacity-10">
                <div class="card-body text-center py-3">
                    <div class="fs-4 fw-bold text-secondary">@bots.Count(b => !b.IsActive)</div>
                    <div class="small text-muted">Inactive</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Name</th>
                            <th>Username</th>
                            <th>Status</th>
                            <th>Running</th>
                            <th>Created</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bot in bots)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-semibold">@bot.Name</div>
                                    @if (!string.IsNullOrEmpty(bot.WelcomeMessage))
                                    {
                                        <div class="small text-muted text-truncate" style="max-width: 250px;">@bot.WelcomeMessage</div>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border px-3 py-2 rounded-2">
                                        <span class="bi bi-at me-1"></span>@bot.Username
                                    </span>
                                </td>
                                <td>
                                    @if (bot.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-2">
                                            <span class="bi bi-check-circle-fill me-1 small"></span> Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2 rounded-2">
                                            <span class="bi bi-x-circle-fill me-1 small"></span> Inactive
                                        </span>
                                    }
                                </td>
                                <td>
                                    @if (bot.IsRunning)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-2">
                                            <span class="bi bi-play-fill me-1 small"></span> Running
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2 rounded-2">
                                            <span class="bi bi-pause-fill me-1 small"></span> Stopped
                                        </span>
                                    }
                                </td>
                                <td>
                                    <span class="text-muted small">
                                        <span class="bi bi-calendar3 me-1"></span> @bot.CreatedAt.ToShortDateString()
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <a href="telegram-bots/edit/@bot.Id" class="btn btn-outline-primary btn-sm rounded-2 me-1" title="Edit">
                                        <span class="bi bi-pencil"></span>
                                    </a>
                                    <a href="telegram-bots/delete/@bot.Id" class="btn btn-outline-danger btn-sm rounded-2" title="Delete">
                                        <span class="bi bi-trash"></span>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private List<TelegramBot>? bots;

    protected override async Task OnInitializedAsync()
    {
        bots = await BotRepo.GetAllAsync();
    }
}
