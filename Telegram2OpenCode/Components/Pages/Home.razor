@page "/"

<PageTitle>Home</PageTitle>

<div class="text-center mb-5 pt-4">
    <div class="mb-3" style="font-size: 3.5rem;">🤖</div>
    <h1 class="display-5 fw-bold">Telegram2OpenCode</h1>
    <p class="lead text-muted mx-auto" style="max-width: 600px;">
        Management platform for OpenCode agents and sessions via Telegram bots.
    </p>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-md-4">
        <a href="ai-agents" class="text-decoration-none">
            <div class="card border-0 shadow-sm rounded-3 h-100 hover-shadow">
                <div class="card-body text-center p-4">
                    <div class="mb-3 text-primary" style="font-size: 2.5rem;">🧠</div>
                    <h5 class="card-title fw-semibold">AI Agents</h5>
                    <p class="card-text text-muted small">
                        Configure AI agents, their models, and system prompts.
                    </p>
                    <span class="btn btn-outline-primary btn-sm rounded-2">Manage Agents</span>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-4">
        <a href="telegram-bots" class="text-decoration-none">
            <div class="card border-0 shadow-sm rounded-3 h-100 hover-shadow">
                <div class="card-body text-center p-4">
                    <div class="mb-3 text-primary" style="font-size: 2.5rem;">💬</div>
                    <h5 class="card-title fw-semibold">Telegram Bots</h5>
                    <p class="card-text text-muted small">
                        Link and manage your Telegram bots to interact with OpenCode.
                    </p>
                    <span class="btn btn-outline-primary btn-sm rounded-2">Manage Bots</span>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3 mt-4">
    <div class="card-body p-4">
        <h5 class="fw-semibold mb-3">How it works</h5>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="d-flex gap-3">
                    <span class="badge bg-primary rounded-circle" style="width: 2rem; height: 2rem; font-size: 0.9rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">1</span>
                    <div>
                        <h6 class="fw-semibold mb-1">Configure an AI Agent</h6>
                        <p class="small text-muted mb-0">Set the model, prompt, and behavior for the agent.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="d-flex gap-3">
                    <span class="badge bg-primary rounded-circle" style="width: 2rem; height: 2rem; font-size: 0.9rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">2</span>
                    <div>
                        <h6 class="fw-semibold mb-1">Link a Telegram Bot</h6>
                        <p class="small text-muted mb-0">Add your Telegram bot token.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="d-flex gap-3">
                    <span class="badge bg-primary rounded-circle" style="width: 2rem; height: 2rem; font-size: 0.9rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">3</span>
                    <div>
                        <h6 class="fw-semibold mb-1">Interact from Telegram</h6>
                        <p class="small text-muted mb-0">Send messages to your bot and get responses from OpenCode.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
