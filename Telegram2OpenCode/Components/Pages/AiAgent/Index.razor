@page "/ai-agents"
@rendermode InteractiveServer
@inject IAiAgentRepository AgentRepo

<PageTitle>Ai Agents</PageTitle>

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="display-6 fw-semibold mb-1">AI Agents</h1>
            <p class="text-muted mb-0">Manage your AI agent configurations</p>
        </div>
        <a href="ai-agents/create" class="btn btn-primary rounded-2 px-4">
            <span class="bi bi-plus-lg me-1"></span> Create Agent
        </a>
    </div>
</div>

@if (agents is null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 text-muted">Loading agents...</p>
    </div>
}
else if (agents.Count == 0)
{
    <div class="text-center py-5">
        <div class="mb-3" style="font-size: 3rem;">🤖</div>
        <h4 class="fw-semibold">No AI agents yet</h4>
        <p class="text-muted mb-3">Create your first agent to get started.</p>
        <a href="ai-agents/create" class="btn btn-primary rounded-2 px-4">
            <span class="bi bi-plus-lg me-1"></span> Create Agent
        </a>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-3 bg-primary bg-opacity-10">
                <div class="card-body text-center py-3">
                    <div class="fs-4 fw-bold text-primary">@agents.Count</div>
                    <div class="small text-muted">Total Agents</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-3 bg-success bg-opacity-10">
                <div class="card-body text-center py-3">
                    <div class="fs-4 fw-bold text-success">@agents.Count(a => a.IsActive)</div>
                    <div class="small text-muted">Active</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-3 bg-secondary bg-opacity-10">
                <div class="card-body text-center py-3">
                    <div class="fs-4 fw-bold text-secondary">@agents.Count(a => !a.IsActive)</div>
                    <div class="small text-muted">Inactive</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-3 bg-info bg-opacity-10">
                <div class="card-body text-center py-3">
                    <div class="fs-4 fw-bold text-info">@string.Join(", ", agents.Select(a => a.Model).Distinct())</div>
                    <div class="small text-muted">Models</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Name</th>
                            <th>Model</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var agent in agents)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-semibold">@agent.Name</div>
                                    @if (!string.IsNullOrEmpty(agent.Description))
                                    {
                                        <div class="small text-muted text-truncate" style="max-width: 250px;">@agent.Description</div>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border px-3 py-2 rounded-2">@agent.Model</span>
                                </td>
                                <td>
                                    @if (agent.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-2">
                                            <span class="bi bi-check-circle-fill me-1 small"></span> Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2 rounded-2">
                                            <span class="bi bi-x-circle-fill me-1 small"></span> Inactive
                                        </span>
                                    }
                                </td>
                                <td>
                                    <span class="text-muted small">
                                        <span class="bi bi-calendar3 me-1"></span> @agent.CreatedAt.ToShortDateString()
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <a href="ai-agents/edit/@agent.Id" class="btn btn-outline-primary btn-sm rounded-2 me-1" title="Edit">
                                        <span class="bi bi-pencil"></span>
                                    </a>
                                    <a href="ai-agents/delete/@agent.Id" class="btn btn-outline-danger btn-sm rounded-2" title="Delete">
                                        <span class="bi bi-trash"></span>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private List<AiAgent>? agents;

    protected override async Task OnInitializedAsync()
    {
        agents = await AgentRepo.GetAllAsync();
    }
}
