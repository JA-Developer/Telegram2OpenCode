@page "/ai-agents/delete/{Id:int}"
@rendermode InteractiveServer
@inject IAiAgentRepository AgentRepo
@inject NavigationManager Navigation

<PageTitle>Delete AiAgent</PageTitle>

<h1>Delete Ai Agent</h1>

@if (entity is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="alert alert-danger">
        <h4>Are you sure you want to delete this?</h4>
    </div>

    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@entity.Name</dd>

        <dt class="col-sm-2">Model</dt>
        <dd class="col-sm-10">@entity.Model</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@entity.Description</dd>

        <dt class="col-sm-2">Active</dt>
        <dd class="col-sm-10">@entity.IsActive</dd>
    </dl>

    <form>
        <button type="submit" class="btn btn-danger" @onclick="HandleDelete">Delete</button>
        <a href="ai-agents" class="btn btn-secondary">Cancel</a>
    </form>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private AiAgent? entity;

    protected override async Task OnInitializedAsync()
    {
        entity = await AgentRepo.GetByIdAsync(Id);
    }

    private async Task HandleDelete()
    {
        await AgentRepo.DeleteAsync(Id);
        Navigation.NavigateTo("ai-agents");
    }
}
