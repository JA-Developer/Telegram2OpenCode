@page "/ai-agents/edit/{Id:int}"
@rendermode InteractiveServer
@inject IAiAgentRepository AgentRepo
@inject NavigationManager Navigation

<PageTitle>Edit Ai Agent</PageTitle>

<div class="mb-4">
    <a href="ai-agents" class="btn btn-sm btn-outline-secondary rounded-2 mb-2">
        <span class="bi bi-arrow-left me-1"></span> Back to list
    </a>
    <h1 class="display-6 fw-semibold">Edit AI Agent</h1>
    <p class="text-muted">Update the agent configuration.</p>
</div>

@if (entity is null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 text-muted">Loading agent...</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-4">
            <EditForm Model="@dto" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" />

                <div class="mb-3">
                    <label for="name" class="form-label fw-semibold">Name</label>
                    <InputText id="name" class="form-control rounded-2" @bind-Value="dto.Name" />
                    <ValidationMessage For="@(() => dto.Name)" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="model" class="form-label fw-semibold">Model</label>
                    <InputText id="model" class="form-control rounded-2" @bind-Value="dto.Model" />
                    <ValidationMessage For="@(() => dto.Model)" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label fw-semibold">Description</label>
                    <InputTextArea id="description" class="form-control rounded-2" @bind-Value="dto.Description" rows="2" />
                </div>

                <div class="mb-4">
                    <label for="systemPrompt" class="form-label fw-semibold">System Prompt</label>
                    <InputTextArea id="systemPrompt" class="form-control rounded-2 font-monospace" @bind-Value="dto.SystemPrompt" rows="6" />
                    <div class="form-text">Defines the base behavior and personality of the agent.</div>
                </div>

                <div class="mb-4 form-check form-switch">
                    <InputCheckbox id="isActive" class="form-check-input" @bind-Value="dto.IsActive" />
                    <label for="isActive" class="form-check-label fw-semibold">Active</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-2 px-4">
                        <span class="bi bi-check-lg me-1"></span> Save
                    </button>
                    <a href="ai-agents" class="btn btn-outline-secondary rounded-2 px-4">Cancel</a>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private AiAgent? entity;
    private UpdateAiAgentDto dto = new();

    protected override async Task OnInitializedAsync()
    {
        entity = await AgentRepo.GetByIdAsync(Id);

        if (entity is not null)
        {
            dto.Name = entity.Name;
            dto.Description = entity.Description;
            dto.SystemPrompt = entity.SystemPrompt;
            dto.Model = entity.Model;
            dto.IsActive = entity.IsActive;
        }
    }

    private async Task HandleSubmit()
    {
        if (entity is null) return;

        entity.ApplyUpdate(dto);
        await AgentRepo.UpdateAsync(entity);
        Navigation.NavigateTo("ai-agents");
    }
}
